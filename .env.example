# ============================================
# Resume+ 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env
# ============================================

# ============ 必填 ============

# DeepSeek AI 密钥（V4-Flash / V4-Pro）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# SiliconFlow 密钥（BGE-M3 嵌入 + Qwen 降级模型）
EMBEDDING_API_KEY=sk-your-siliconflow-api-key

# PostgreSQL 密码（PGVector 向量数据库）
PGVECTOR_PASSWORD=your-pgvector-password

# JWT 签名密钥（用 openssl rand -base64 32 生成）
JWT_SECRET=your-jwt-secret-base64-or-random-string

# MySQL root 密码
MYSQL_PASSWORD=your-mysql-password

# ============ 可选 ============

# MinIO 对象存储（部署模式不必须，改用本地存储）
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# MySQL 用户名（默认 root）
MYSQL_USERNAME=root

# ----- 以下保持默认即可，无需修改 -----

# 阿里云短信（需要企业资质）
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_SECRET=

# 微信登录（需要企业资质）
# WX_APP_SECRET=

# Windows 开发环境
# WINDOWS_MYSQL_PASSWORD=
# WINDOWS_MINIO_SECRET_KEY=
# WINDOWS_RABBITMQ_PASSWORD=
# WINDOWS_JWT_SECRET=

# RabbitMQ
# RABBITMQ_PASSWORD=

# Druid 监控密码
# DRUID_PASSWORD=
