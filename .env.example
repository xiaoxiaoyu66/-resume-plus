# ============================================
# Resume+ 环境变量配置
# 复制此文件为 .env 并填入你的密钥
# cp .env.example .env
# ============================================

# ----- DeepSeek AI -----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
EMBEDDING_API_KEY=sk-your-siliconflow-api-key

# ----- MinIO 对象存储 -----
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# ----- PGVector 向量数据库 -----
PGVECTOR_PASSWORD=your-pgvector-password

# ----- JWT -----
JWT_SECRET=your-jwt-secret-base64-or-random-string

# ----- MySQL -----
MYSQL_USERNAME=root
MYSQL_PASSWORD=your-mysql-password

# ----- 阿里云短信（可选）-----
# ALIYUN_SMS_ACCESS_KEY_ID=
# ALIYUN_SMS_SECRET=

# ----- 微信登录（可选）-----
# WX_APP_SECRET=

# ----- Windows 开发环境（可选）-----
# WINDOWS_MYSQL_PASSWORD=
# WINDOWS_MINIO_SECRET_KEY=
# WINDOWS_RABBITMQ_PASSWORD=
# WINDOWS_JWT_SECRET=

# ----- RabbitMQ（可选）-----
# RABBITMQ_PASSWORD=

# ----- Druid 监控（可选）-----
# DRUID_PASSWORD=
