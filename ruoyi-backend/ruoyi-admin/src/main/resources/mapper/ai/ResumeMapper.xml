<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.ruoyi.web.controller.ai.mapper.ResumeMapper">

    <resultMap id="ResumeResult" type="com.ruoyi.web.controller.ai.domain.Resume">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="templateId" column="template_id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="isDefault" column="is_default"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectResumeVo">
        SELECT id, user_id, template_id, title, content, is_default, create_time, update_time
        FROM resume
    </sql>

    <select id="selectResumeById" parameterType="Long" resultMap="ResumeResult">
        <include refid="selectResumeVo"/>
        WHERE id = #{id}
    </select>

    <select id="selectResumeListByUserId" parameterType="Long" resultMap="ResumeResult">
        <include refid="selectResumeVo"/>
        WHERE user_id = #{userId}
        ORDER BY is_default DESC, update_time DESC
    </select>

    <insert id="insertResume" parameterType="com.ruoyi.web.controller.ai.domain.Resume" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO resume
        <trim prefix="(" suffix=")" suffixOverrides=",">
            user_id,
            <if test="templateId != null and templateId != ''">template_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="isDefault != null">is_default,</if>
            create_time, update_time
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            #{userId},
            <if test="templateId != null and templateId != ''">#{templateId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="isDefault != null">#{isDefault},</if>
            now(), now()
        </trim>
    </insert>

    <update id="updateResume" parameterType="com.ruoyi.web.controller.ai.domain.Resume">
        UPDATE resume
        <set>
            <if test="templateId != null">template_id = #{templateId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="content != null">content = #{content},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            update_time = now()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteResumeById" parameterType="Long">
        DELETE FROM resume WHERE id = #{id}
    </delete>

    <update id="cancelDefaultByUserId" parameterType="Long">
        UPDATE resume SET is_default = 0 WHERE user_id = #{userId}
    </update>

</mapper>